{
  "manifest_version": 3,
  "key": "",
  "name": "JSON Keeper",
  "version": "0.9.0",
  "description": "View, format and copy JSON \u2014 with an obvious paste box, one-click valid-JSON copy, and big integers that never lose precision.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*",
    "file:///*"
  ],
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*",
        "file:///*"
      ],
      "run_at": "document_end",
      "js": [
        "jsonbig.js",
        "util.js",
        "tree.js",
        "jsonpath.js",
        "toolbar.js",
        "search.js",
        "query.js",
        "table.js",
        "schema-infer.js",
        "schema-validate.js",
        "panel.js",
        "rail.js",
        "status.js",
        "core.js",
        "content.js"
      ],
      "css": [
        "tokens.css",
        "viewer.css"
      ]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "JSON Keeper"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
